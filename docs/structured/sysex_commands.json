{
  "_meta": {
    "source": "Extracted from app.electra.one JS bundle (0c61af0.js + 404 lazy chunks) + docs.electra.one/developers/midiimplementation.html + filetransfer.html",
    "firmware_baseline": "4.1.4",
    "research_date": "2026-05-26",
    "ack_format": {
      "ok": "F0 00 21 45 7E 01 <txid-lsb> <txid-msb> F7",
      "nack": "F0 00 21 45 7E 00 <txid-lsb> <txid-msb> F7",
      "note": "Transaction id is optional (firmware >= 4.0). If sent, it's inserted as `00 <lsb> <msb>` right after the manufacturer id (00 21 45). ACKs/NACKs echo the txid back, or use 00 00 if none was sent."
    },
    "manufacturer_id": "00 21 45"
  },

  "queries": [
    { "name": "Get Info",                "bytes": "F0 00 21 45 02 7F F7", "payload": null,                              "response_prefix": "F0 00 21 45 01 7F", "response_body": "info-json",        "purpose": "firmware version, serial, model",                                 "doc": "https://docs.electra.one/developers/midiimplementation.html#get-electra-info" },
    { "name": "Get Runtime Info",        "bytes": "F0 00 21 45 02 7E F7", "payload": null,                              "response_prefix": "F0 00 21 45 01 7E", "response_body": "runtime-json",     "purpose": "free-memory percent, uptime",                                     "doc": "https://docs.electra.one/developers/midiimplementation.html#get-runtime-information" },
    { "name": "Get Active Preset",       "bytes": "F0 00 21 45 02 01 F7", "payload": "optional bank slot",              "response_prefix": "F0 00 21 45 01 01", "response_body": "preset-json",      "purpose": "fetch preset.json from currently-active slot (or specific slot)", "doc": "https://docs.electra.one/developers/midiimplementation.html#get-preset" },
    { "name": "Get Lua Script",          "bytes": "F0 00 21 45 02 0C F7", "payload": "optional bank slot",              "response_prefix": "F0 00 21 45 01 0C", "response_body": "lua-source-text",  "purpose": "fetch main.lua from slot",                                        "doc": "https://docs.electra.one/developers/midiimplementation.html#get-lua-script" },
    { "name": "Get Device Overrides",    "bytes": "F0 00 21 45 02 0F F7", "payload": "optional bank slot",              "response_prefix": "F0 00 21 45 01 0F", "response_body": "devices-json",     "purpose": "fetch devices.json (device routing overrides) from slot",         "doc": "https://docs.electra.one/developers/midiimplementation.html#get-device-overrides" },
    { "name": "Get Persisted Data",      "bytes": "F0 00 21 45 02 12 F7", "payload": "optional bank slot",              "response_prefix": "F0 00 21 45 01 12", "response_body": "data-json",        "purpose": "fetch data.json (Lua persist() table) from slot",                 "doc": "https://docs.electra.one/developers/midiimplementation.html#get-persisted-data" },
    { "name": "Get Performance",         "bytes": "F0 00 21 45 02 11 F7", "payload": "bank slot",                       "response_prefix": "F0 00 21 45 01 11", "response_body": "performance-json", "purpose": "fetch performance.json from slot",                                "doc": "https://docs.electra.one/developers/midiimplementation.html#get-performance" },
    { "name": "Get Configuration",       "bytes": "F0 00 21 45 02 02 F7", "payload": null,                              "response_prefix": "F0 00 21 45 01 02", "response_body": "config-json",      "purpose": "fetch system configuration",                                      "doc": "https://docs.electra.one/developers/midiimplementation.html#get-configuration" },
    { "name": "Get Preset List",         "bytes": "F0 00 21 45 02 04 F7", "payload": null,                              "response_prefix": "F0 00 21 45 01 04", "response_body": "preset-list-json", "purpose": "list every preset slot (name, projectId, bank, slot, hasLua)",    "doc": "https://docs.electra.one/developers/midiimplementation.html#get-preset-list" },
    { "name": "Get Preset Slot Info",    "bytes": "F0 00 21 45 02 08 <bank> <slot> F7", "payload": "bank slot",          "response_prefix": "F0 00 21 45 01 04", "response_body": "slot-info-json",   "purpose": "metadata + file list + MD5s for one slot",                        "doc": "https://docs.electra.one/developers/midiimplementation.html#get-preset-slot-information" },
    { "name": "Get Snapshot List",       "bytes": "F0 00 21 45 02 05 <json> F7", "payload": "{\"projectId\":\"...\"}",  "response_prefix": "F0 00 21 45 01 05", "response_body": "snap-list-json",   "purpose": "list snapshots for a project",                                    "doc": "https://docs.electra.one/developers/midiimplementation.html" },
    { "name": "Get Snapshot",            "bytes": "F0 00 21 45 02 03 <json> F7", "payload": "{\"projectId\":\"\",\"bankNumber\":N,\"slot\":M}", "response_prefix": "F0 00 21 45 01 03", "response_body": "snapshot-json", "purpose": "fetch parameter values for one snapshot",                "doc": "https://docs.electra.one/developers/midiimplementation.html" },
    { "name": "Get USB Host Devices",    "bytes": "F0 00 21 45 02 10 F7", "payload": null,                              "response_prefix": "F0 00 21 45 01 10", "response_body": "usb-devices-json", "purpose": "list MIDI devices connected to the USB Host port",                "doc": "https://docs.electra.one/developers/midiimplementation.html" },
    { "name": "Get Location Files",      "bytes": "F0 00 21 45 02 34 <json> F7", "payload": "{\"location\":\"slots|modules|presets|...\",...}", "response_prefix": "F0 00 21 45 01 34", "response_body": "location-json", "purpose": "list files in a storage location (used by File Transfer API)", "doc": "https://docs.electra.one/developers/filetransfer.html#get-location-files" }
  ],

  "uploads_simple": [
    { "name": "Upload Preset",           "bytes": "F0 00 21 45 01 01 <preset-json> F7", "payload": "preset JSON (controls schema)", "purpose": "upload preset.json to currently-active slot; immediately activates",                       "doc": "https://docs.electra.one/developers/midiimplementation.html#upload-preset" },
    { "name": "Upload Lua Script",       "bytes": "F0 00 21 45 01 0C <lua-source> F7",  "payload": "lua source text",               "purpose": "upload main.lua to currently-active slot; executed immediately",                            "doc": "https://docs.electra.one/developers/midiimplementation.html#upload-lua-script" },
    { "name": "Upload Device Overrides", "bytes": "F0 00 21 45 01 0F <devices-json> F7","payload": "devices JSON",                  "purpose": "upload devices.json to active slot",                                                       "doc": "https://docs.electra.one/developers/midiimplementation.html#upload-device-overrides" },
    { "name": "Upload Persisted Data",   "bytes": "F0 00 21 45 01 12 <data-json> F7",   "payload": "data JSON",                     "purpose": "upload data.json (persist() Lua table) to active slot",                                    "doc": "https://docs.electra.one/developers/midiimplementation.html#upload-persisted-data" },
    { "name": "Upload Performance",      "bytes": "F0 00 21 45 01 11 <perf-json> F7",   "payload": "performance JSON",              "purpose": "upload performance.json to active slot",                                                   "doc": "https://docs.electra.one/developers/midiimplementation.html#upload-performance" },
    { "name": "Upload Configuration",    "bytes": "F0 00 21 45 01 02 <config-json> F7", "payload": "configuration JSON",            "purpose": "upload system-wide configuration",                                                         "doc": "https://docs.electra.one/developers/midiimplementation.html#upload-configuration" }
  ],

  "file_transfer": [
    { "name": "Open Cache",              "bytes": "F0 00 21 45 01 2D F7",               "payload": null,                                              "purpose": "begin a multi-file atomic transfer transaction; clears any prior unfinished cache",       "doc": "https://docs.electra.one/developers/filetransfer.html#open-the-cache" },
    { "name": "Register File",           "bytes": "F0 00 21 45 01 2E <fid> <s0> <s1> <s2> <s3> F7", "payload": "fileId (1B) + size as four 7-bit LE bytes", "purpose": "declare a file's id + size before sending its chunks",                              "doc": "https://docs.electra.one/developers/filetransfer.html#register-the-files" },
    { "name": "Transfer Chunk",          "bytes": "F0 00 21 45 01 2F <fid> <7-bit data> F7", "payload": "fileId (1B) + chunk bytes (ASCII or 7-bit-encoded)", "purpose": "send a chunk of a previously-registered file",                                       "doc": "https://docs.electra.one/developers/filetransfer.html#transfer-chunks" },
    { "name": "Commit Files",            "bytes": "F0 00 21 45 04 2D <commit-json> F7", "payload": "{\"files\":[{\"id\":N,\"location\":\"slots|modules|...\",\"type\":\"preset|lua|luaModule|...\",\"bankNumber\":B,\"slot\":S,\"md5\":\"hex\"}]}", "purpose": "finalise the transfer; device verifies MD5 per file and moves them to their final locations", "doc": "https://docs.electra.one/developers/filetransfer.html#commit-the-transaction" }
  ],

  "navigation_runtime": [
    { "name": "Switch Preset Slot",      "bytes": "F0 00 21 45 09 08 <bank> <slot> F7", "payload": "bank slot",                  "purpose": "change the active preset slot (loads the slot if it has a preset)",                  "doc": "https://docs.electra.one/developers/midiimplementation.html#switch-preset-slot" },
    { "name": "Set Preset Slot",         "bytes": "F0 00 21 45 14 08 <bank> <slot> F7", "payload": "bank slot",                  "purpose": "arm a slot as 'selected' for subsequent operations, without loading it",              "doc": "https://docs.electra.one/developers/midiimplementation.html#set-preset-slot" },
    { "name": "Switch Page",             "bytes": "F0 00 21 45 09 0A <page> F7",        "payload": "page number",                "purpose": "change the active display page within the current preset",                           "doc": "https://docs.electra.one/developers/midiimplementation.html#switch-page" },
    { "name": "Switch Control Set",      "bytes": "F0 00 21 45 09 0B <set-id> F7",      "payload": "control set id",             "purpose": "change which set of knobs is mapped to the on-screen controls",                      "doc": "https://docs.electra.one/developers/midiimplementation.html#switch-control-set" },
    { "name": "Reload Preset Slot",      "bytes": "F0 00 21 45 08 08 F7",               "payload": null,                         "purpose": "reinitialise the currently-running preset from disk (NACKs on FW 4.1.4 in our tests)", "doc": "https://docs.electra.one/developers/midiimplementation.html#reload-preset-slot" },
    { "name": "Execute Lua (one-shot)",  "bytes": "F0 00 21 45 08 0D <lua-source> F7",  "payload": "ascii Lua, up to 65 KB",     "purpose": "RUN Lua but do not persist (REPL-style) — use 01 0C to save instead",                "doc": "https://docs.electra.one/developers/midiimplementation.html#execute-lua" },
    { "name": "Execute Lua (legacy)",    "bytes": "F0 00 21 45 08 0C <lua-source> F7",  "payload": "ascii Lua, up to 128 B",     "purpose": "pre-4.0 one-shot Lua exec (use 08 0D on 4.x)",                                        "doc": "https://docs.electra.one/developers/midiimplementation.html" },
    { "name": "Update Control",          "bytes": "F0 00 21 45 14 07 <id-lsb> <id-msb> <update-json> F7", "payload": "controlId (2×7-bit LE) + {name,color,visible,value} JSON", "purpose": "live-edit a single control (runtime only, lost on reboot)", "doc": "https://docs.electra.one/developers/midiimplementation.html#update-control" },
    { "name": "Override Value Text",     "bytes": "F0 00 21 45 14 0E <id-lsb> <id-msb> <valueId> <text> F7", "payload": "controlId + valueId + display text", "purpose": "override the display text for one value (runtime)", "doc": "https://docs.electra.one/developers/midiimplementation.html" },
    { "name": "Set Bottom Bar Text",     "bytes": "F0 00 21 45 14 77 <text> F7",        "payload": "<= 40 chars ASCII",          "purpose": "set the status-bar text at the bottom of the screen (runtime)",                      "doc": "https://docs.electra.one/developers/midiimplementation.html" },
    { "name": "Set Events Port",         "bytes": "F0 00 21 45 14 7B <port> F7",        "payload": "0=port1, 1=port2, 2=CTRL",   "purpose": "route 7E XX event notifications to a specific USB MIDI port",                        "doc": "https://docs.electra.one/developers/midiimplementation.html#set-event-port" },
    { "name": "Subscribe Events",        "bytes": "F0 00 21 45 14 79 <flag-byte> F7",   "payload": "bitmask: 0x01=page 0x02=ctrlset 0x04=usb 0x08=pots 0x10=touch 0x20=button 0x40=window", "purpose": "subscribe to additional event categories (page+pots are on by default per docs)", "doc": "https://docs.electra.one/developers/midiimplementation.html#subscribe-events" },
    { "name": "Set Logger Port",         "bytes": "F0 00 21 45 14 7D <port> <reserved> F7", "payload": "port byte",              "purpose": "route logger output (print(), errors) to a specific USB MIDI port",                  "doc": "https://docs.electra.one/developers/midiimplementation.html" },
    { "name": "Control Logger",          "bytes": "F0 00 21 45 7F 7D <status> <level> F7", "payload": "0=off 1=on; level 0-3",  "purpose": "enable/disable logger output (persisted)",                                            "doc": "https://docs.electra.one/developers/midiimplementation.html" },
    { "name": "Control Window Repaints", "bytes": "F0 00 21 45 7F 7A <cmd> <reserved> F7", "payload": "0=stop, 1=resume",       "purpose": "batch graphics updates (host pauses device repaints during heavy updates)",          "doc": "https://docs.electra.one/developers/midiimplementation.html" },
    { "name": "Reboot",                  "bytes": "F0 00 21 45 7F 78 F7",               "payload": null,                         "purpose": "soft-reboot the device",                                                              "doc": "https://docs.electra.one/developers/midiimplementation.html" },
    { "name": "Load Preloaded Preset",   "bytes": "F0 00 21 45 04 08 <bank> <slot> <json> F7", "payload": "bank slot + {\"preset\":\"<name>\"}", "purpose": "load a preset from /ctrlv2/presets (preloaded library) into a slot",        "doc": "https://docs.electra.one/developers/midiimplementation.html" }
  ],

  "persistent_changes": [
    { "name": "Remove Preset",           "bytes": "F0 00 21 45 05 01 <bank> <slot> F7", "payload": "bank slot",                  "purpose": "delete preset slot (clears all files in it)",                                         "doc": "https://docs.electra.one/developers/midiimplementation.html#remove-preset" },
    { "name": "Remove Lua Script",       "bytes": "F0 00 21 45 05 0C <bank> <slot> F7", "payload": "bank slot",                  "purpose": "delete main.lua only, leave other slot files intact",                                 "doc": "https://docs.electra.one/developers/midiimplementation.html#remove-lua-script" },
    { "name": "Remove Configuration",    "bytes": "F0 00 21 45 05 02 F7",               "payload": null,                         "purpose": "delete the system configuration",                                                     "doc": "https://docs.electra.one/developers/midiimplementation.html" },
    { "name": "Remove Snapshot",         "bytes": "F0 00 21 45 05 06 <json> F7",        "payload": "{\"projectId\":\"\",\"bankNumber\":N,\"slot\":M}", "purpose": "delete one snapshot",                                                  "doc": "https://docs.electra.one/developers/midiimplementation.html" },
    { "name": "Clear Preset Slot",       "bytes": "F0 00 21 45 05 08 <bank> <slot> F7", "payload": "bank slot",                  "purpose": "clear all files in a slot (alternative to Remove Preset)",                            "doc": "https://docs.electra.one/developers/midiimplementation.html#clear-preset-slot-files" },
    { "name": "Remove Location Files",   "bytes": "F0 00 21 45 05 34 <json> F7",        "payload": "{\"location\":\"...\",...}", "purpose": "delete files from a storage location (Lua modules, preloaded presets, etc.)",         "doc": "https://docs.electra.one/developers/filetransfer.html#remove-files-from-location" },
    { "name": "Update Snapshot",         "bytes": "F0 00 21 45 04 06 <json> F7",        "payload": "{\"projectId\":\"\",\"bankNumber\":N,\"slot\":M,\"name\":\"\",\"color\":\"\"}", "purpose": "update snapshot metadata (name, color)", "doc": "https://docs.electra.one/developers/midiimplementation.html" },
    { "name": "Swap Snapshots",          "bytes": "F0 00 21 45 06 06 <json> F7",        "payload": "{\"projectId\":\"\",\"fromBank\":N,\"fromSlot\":M,\"toBank\":X,\"toSlot\":Y}", "purpose": "swap or move two snapshots", "doc": "https://docs.electra.one/developers/midiimplementation.html" }
  ],

  "events_device_to_host": [
    { "name": "ACK",                     "bytes": "F0 00 21 45 7E 01 <txid-lsb> <txid-msb> F7", "purpose": "command succeeded; txid echoes the request's tx id (00 00 if none)" },
    { "name": "NACK",                    "bytes": "F0 00 21 45 7E 00 <txid-lsb> <txid-msb> F7", "purpose": "command failed" },
    { "name": "Preset Switch",           "bytes": "F0 00 21 45 7E 02 <bank> <slot> F7",         "purpose": "user changed preset" },
    { "name": "Snapshot List Change",    "bytes": "F0 00 21 45 7E 03 F7",                       "purpose": "snapshots added/removed/modified for current project" },
    { "name": "Snapshot Bank Switch",    "bytes": "F0 00 21 45 7E 04 <bank> F7",                "purpose": "user changed the active snapshot bank" },
    { "name": "Preset List Change",      "bytes": "F0 00 21 45 7E 05 F7",                       "purpose": "presets added/removed/modified (fires after a successful preset commit too)" },
    { "name": "Page Switch",             "bytes": "F0 00 21 45 7E 06 <page> F7",                "purpose": "user changed the active display page" },
    { "name": "Control Set Switch",      "bytes": "F0 00 21 45 7E 07 <set> F7",                 "purpose": "user changed the active control set" },
    { "name": "Preset Bank Switch",      "bytes": "F0 00 21 45 7E 08 <bank> F7",                "purpose": "user changed the active preset bank" },
    { "name": "Pot Touch",               "bytes": "F0 00 21 45 7E 0A <pot> <ctrl-lsb> <ctrl-msb> <touched> F7", "purpose": "pot was touched or released (touched: 0=release, 1=touch)" },
    { "name": "Transfer Progress",       "bytes": "F0 00 21 45 7E 2D <s0> <s1> <s2> <s3> F7",   "purpose": "during file transfer: cumulative bytes transferred (size as four 7-bit LE)" },
    { "name": "Capture List Change",     "bytes": "F0 00 21 45 7E 31 F7",                       "purpose": "captures added/removed/modified" },
    { "name": "Log Message",             "bytes": "F0 00 21 45 7F 00 <ts> <text> F7",           "purpose": "print() output and firmware error messages from the device; <ts> is millisecond timestamp" }
  ]
}
